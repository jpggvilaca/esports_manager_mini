custom_minimum_size = Vector2(56, 56)
expand_mode = 3
stretch_mode = 6

[node name="LevelLabel" type="Label" parent="Margin/VBox/ContentRow/PortraitColumn"]
layout_mode = 2
theme_override_font_sizes/font_size = 11
theme_override_colors/font_color = Color(0.55, 0.80, 1.0, 1.0)
horizontal_alignment = 1
text = "Lv.1"

[node name="StatBars" parent="Margin/VBox/ContentRow" instance=ExtResource("2_bars")]
