[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://ui/components/PlayerPanel.gd" id="1_panel"]
[ext_resource type="PackedScene" path="res://ui/components/PlayerStatBars.tscn" id="2_bars"]

[node name="PlayerPanel" type="PanelContainer"]
script = ExtResource("1_panel")

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 12
theme_override_constants/margin_right = 12
theme_override_constants/margin_top = 10
theme_override_constants/margin_bottom = 10

[node name="VBox" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="HeaderRow" type="HBoxContainer" parent="Margin/VBox"]
layout_mode = 2

[node name="NameLabel" type="Label" parent="Margin/VBox/HeaderRow"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_font_sizes/font_size = 17

[node name="TraitBadge" type="Label" parent="Margin/VBox/HeaderRow"]
layout_mode = 2
theme_override_font_sizes/font_size = 12
theme_override_colors/font_color = Color(0.6, 0.85, 1.0, 1.0)

[node name="FormLabel" type="Label" parent="Margin/VBox/HeaderRow"]
layout_mode = 2
theme_override_font_sizes/font_size = 12
text = ""

[node name="BioLabel" type="Label" parent="Margin/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 11
theme_override_colors/font_color = Color(0.50, 0.52, 0.60, 1.0)
autowrap_mode = 3
text = ""

[node name="ContentRow" type="HBoxContainer" parent="Margin/VBox"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="PortraitColumn" type="VBoxContainer" parent="Margin/VBox/ContentRow"]
layout_mode = 2
theme_override_constants/separation = 3

[node name="Portrait" type="TextureRect" parent="Margin/VBox/ContentRow/PortraitColumn"]
