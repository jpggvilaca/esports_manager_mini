; PlayerCard.tscn
; Reusable card — hub squad/bench + RosterScreen.
; setup(player, is_active, match_type, portrait, game) binds data.
; Two StyleBoxFlat sub-resources (active / bench) are defined here;
; the script just swaps between them — no StyleBoxFlat construction in code.
[gd_scene format=3]

[ext_resource type="Script" path="res://ui/components/PlayerCard.gd" id="1_pc"]

[sub_resource type="StyleBoxFlat" id="style_active"]
bg_color = Color(0.10, 0.15, 0.10, 1)
border_color = Color(0.25, 0.75, 0.38, 1)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
corner_radius_top_left = 4
corner_radius_top_right = 4
corner_radius_bottom_left = 4
corner_radius_bottom_right = 4

[sub_resource type="StyleBoxFlat" id="style_bench"]
bg_color = Color(0.09, 0.09, 0.13, 1)
border_color = Color(0.22, 0.22, 0.28, 1)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
corner_radius_top_left = 4
corner_radius_top_right = 4
corner_radius_bottom_left = 4
corner_radius_bottom_right = 4

[node name="PlayerCard" type="PanelContainer"]
custom_minimum_size = Vector2(180, 0)
theme_override_styles/panel = SubResource("style_bench")
script = ExtResource("1_pc")

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 10
theme_override_constants/margin_right = 10
theme_override_constants/margin_top = 8
theme_override_constants/margin_bottom = 8

[node name="Row" type="HBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="Portrait" type="TextureRect" parent="Margin/Row"]
layout_mode = 2
size_flags_vertical = 0
custom_minimum_size = Vector2(48, 48)
expand_mode = 1
stretch_mode = 6

[node name="VBox" type="VBoxContainer" parent="Margin/Row"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 3

[node name="NameLabel" type="Label" parent="Margin/Row/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
theme_override_colors/font_color = Color(1, 1, 1, 1)
text = "Player Name"

[node name="TraitLabel" type="Label" parent="Margin/Row/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 10
theme_override_colors/font_color = Color(0.50, 0.75, 1.0, 1)
text = "Trait  ·  Match Trait"

[node name="StaminaRow" type="HBoxContainer" parent="Margin/Row/VBox"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="StaminaLabel" type="Label" parent="Margin/Row/VBox/StaminaRow"]
layout_mode = 2
custom_minimum_size = Vector2(60, 0)
theme_override_font_sizes/font_size = 10
theme_override_colors/font_color = Color(0.58, 0.58, 0.64, 1)
text = "Stamina"

[node name="StaminaBar" type="ProgressBar" parent="Margin/Row/VBox/StaminaRow"]
layout_mode = 2
size_flags_horizontal = 3
custom_minimum_size = Vector2(0, 8)
show_percentage = false
value = 80

[node name="XpRow" type="HBoxContainer" parent="Margin/Row/VBox"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="XpLabel" type="Label" parent="Margin/Row/VBox/XpRow"]
layout_mode = 2
custom_minimum_size = Vector2(60, 0)
theme_override_font_sizes/font_size = 10
theme_override_colors/font_color = Color(0.58, 0.58, 0.64, 1)
text = "Lv.1"

[node name="XpBar" type="ProgressBar" parent="Margin/Row/VBox/XpRow"]
layout_mode = 2
size_flags_horizontal = 3
custom_minimum_size = Vector2(0, 8)
show_percentage = false
modulate = Color(0.40, 0.70, 1.0, 1)
value = 30

[node name="Extras" type="VBoxContainer" parent="Margin/Row/VBox"]
layout_mode = 2
theme_override_constants/separation = 3
