; CandidateCard.tscn
; One row in the Market's "Available" column.
; Bind data via CandidateCard.setup(candidate). Click handled by MarketOverlay via gui_input.
[gd_scene format=3]

[ext_resource type="Script" path="res://ui/components/CandidateCard.gd" id="1_cc"]

[sub_resource type="StyleBoxFlat" id="style_card"]
bg_color = Color(0.14, 0.18, 0.24, 1)
border_color = Color(0.25, 0.35, 0.50, 1)
border_width_left = 1
border_width_top = 1
border_width_right = 1
border_width_bottom = 1
corner_radius_top_left = 3
corner_radius_top_right = 3
corner_radius_bottom_left = 3
corner_radius_bottom_right = 3

[node name="CandidateCard" type="PanelContainer"]
custom_minimum_size = Vector2(0, 90)
theme_override_styles/panel = SubResource("style_card")
script = ExtResource("1_cc")

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 12
theme_override_constants/margin_right = 12
theme_override_constants/margin_top = 10
theme_override_constants/margin_bottom = 10

[node name="VBox" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 4

[node name="Header" type="HBoxContainer" parent="Margin/VBox"]
layout_mode = 2

[node name="NameLabel" type="Label" parent="Margin/VBox/Header"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_font_sizes/font_size = 16
text = "Candidate  Lv.2"

[node name="TraitBadge" type="Label" parent="Margin/VBox/Header"]
layout_mode = 2
theme_override_font_sizes/font_size = 12
theme_override_colors/font_color = Color(0.6, 0.85, 1.0, 1)
text = "[clutch]"

[node name="StatsLabel" type="Label" parent="Margin/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 12
theme_override_colors/font_color = Color(0.70, 0.72, 0.80, 1)
text = "Skill 50  ·  Focus 50  ·  Stamina 65  ·  Morale 60"

[node name="MinorLabel" type="Label" parent="Margin/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 11
theme_override_colors/font_color = Color(0.75, 0.65, 0.45, 1)
visible = false
text = ""

[node name="BioLabel" type="Label" parent="Margin/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 11
theme_override_colors/font_color = Color(0.48, 0.50, 0.58, 1)
autowrap_mode = 3
text = ""
